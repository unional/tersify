{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"composite": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": false,
		"outDir": "esm-tsc",
		"rootDir": "src"
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.spec.ts", "src/**/*.stories.tsx", "src/**/*.mdx"]
}
